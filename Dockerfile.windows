# LLM Workflow Toolkit - Windows Container Dockerfile
# For Windows Server Core or Nanoserver containers

# Base image with PowerShell
FROM mcr.microsoft.com/powershell:windowsservercore-ltsc2022 AS base

# Set environment variables
ENV PYTHON_VERSION=3.11.4 `
    PYTHONUNBUFFERED=1 `
    PIP_NO_CACHE_DIR=1 `
    LLM_WORKFLOW_TOOLKIT_SOURCE="C:\\llm-workflow\\module\\LLMWorkflow\\templates\\tools"

# Install Python using NuGet
USER ContainerAdministrator
RUN powershell -Command `
    $ErrorActionPreference = 'Stop'; `
    Invoke-WebRequest -Uri "https://www.python.org/ftp/python/$env:PYTHON_VERSION/python-$env:PYTHON_VERSION-amd64.exe" -OutFile "python-installer.exe"; `
    Start-Process -FilePath "python-installer.exe" -ArgumentList "/quiet", "InstallAllUsers=1", "PrependPath=1" -Wait; `
    Remove-Item -Force "python-installer.exe"; `
    python -m pip install --upgrade pip setuptools wheel

# Stage 2: Install Python dependencies
FROM base AS python-deps

# Install chromadb and codemunch-pro
RUN python -m pip install chromadb>=0.5.0 codemunch-pro

# Verify installations
RUN python -c "import chromadb; print('ChromaDB:', chromadb.__version__)" && `
    codemunch-pro --version || echo "codemunch-pro installed"

# Stage 3: Final image
FROM base AS final

# Copy Python installation from python-deps
COPY --from=python-deps ["C:/Program Files/Python311", "C:/Program Files/Python311"]
COPY --from=python-deps ["C:/Program Files/Python311/Scripts", "C:/Program Files/Python311/Scripts"]

# Update PATH
RUN setx /M PATH "%PATH%;C:\Program Files\Python311;C:\Program Files\Python311\Scripts"

# Create working directories
RUN mkdir C:\llm-workflow && `
    mkdir C:\workspace && `
    mkdir C:\Users\ContainerAdministrator\Documents\PowerShell\Modules

# Copy module and toolkit files
COPY module/ C:/llm-workflow/module/
COPY tools/ C:/llm-workflow/tools/
COPY docker/ C:/llm-workflow/docker/

# Install PowerShell module
RUN pwsh -NoProfile -Command `
    "$ModulePath = 'C:\\Users\\ContainerAdministrator\\Documents\\PowerShell\\Modules\\LLMWorkflow\\0.2.0'; `
    New-Item -ItemType Directory -Path $ModulePath -Force | Out-Null; `
    Copy-Item -Path 'C:\\llm-workflow\\module\\LLMWorkflow\\*' -Destination $ModulePath -Recurse -Force; `
    Import-Module LLMWorkflow -Force; `
    Write-Host 'Module installed'"

# Copy entrypoint script
COPY docker/entrypoint.ps1 C:/llm-workflow/entrypoint.ps1

# Set working directory
WORKDIR C:\workspace

# Volume for persistent data
VOLUME ["C:\\workspace", "C:\\mempalace"]

# Entrypoint
ENTRYPOINT ["pwsh", "-NoProfile", "-File", "C:\\llm-workflow\\entrypoint.ps1"]

# Default command
CMD ["llmup"]

# Labels
LABEL org.opencontainers.image.title="LLM Workflow Toolkit (Windows)" `
      org.opencontainers.image.description="All-in-one workflow toolkit for Windows containers" `
      org.opencontainers.image.version="0.2.0" `
      org.opencontainers.image.source="https://github.com/DocDamage/CodeMunch-ContextLattice-MemPalace---All-in-one"
