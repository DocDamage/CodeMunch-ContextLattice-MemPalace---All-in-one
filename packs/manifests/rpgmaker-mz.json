  "collections": {
    "rpgmaker_core_api": {
      "description": "Authoritative engine/runtime surfaces",
      "defaultTrust": "High",
      "authorityRole": "core-runtime"
    },
    "rpgmaker_plugin_patterns": {
      "description": "Community plugin patterns and examples",
      "defaultTrust": "Medium",
      "authorityRole": "exemplar-pattern"
    },
    "rpgmaker_tooling": {
      "description": "Conflict finders, translators, decrypters, and workflow tools",
      "defaultTrust": "Medium",
      "authorityRole": "tooling-analyzer"
    },
    "rpgmaker_llm_workflows": {
      "description": "LLM-specific project tooling and translation workflows",
      "defaultTrust": "Medium",
      "authorityRole": "llm-workflow"
    },
    "rpgmaker_private_project": {
      "description": "User-authored plugins, notes, and project-specific patterns",
      "defaultTrust": "High",
      "authorityRole": "private-project"
    }
  },
  "extractionConfig": {
    "modulePath": "module/LLMWorkflow/extraction",
    "pipelineModule": "ExtractionPipeline.ps1",
    "parserModules": {
      "rpgmakerPlugin": "RPGMakerPluginParser.ps1"
    },
    "fileExtensions": {
      ".js": {
        "parser": "RPGMakerPluginParser.ps1",
        "function": "Invoke-RPGMakerPluginParse",
        "extractionType": "rpgmakerPlugin",
        "contentCheck": {
          "pattern": "@target|@plugindesc|@param|@command",
          "description": "RPG Maker plugin header pattern"
        }
      }
    }
  },
  "extractionTargets": {
    "plugin_headers": {
      "description": "Plugin header extraction with @target, @base, @orderAfter, @orderBefore, etc.",
      "required": true,
      "parserFunction": "Get-PluginMetadata"
    },
    "plugin_commands": {
      "description": "Plugin command extraction",
      "required": true,
      "parserFunction": "Get-PluginCommands"
    },
    "plugin_params": {
      "description": "Plugin parameter schemas",
      "required": true,
      "parserFunction": "Get-PluginParameters"
    },
    "notetag_catalog": {
      "description": "Notetag extraction",
      "required": true,
      "parserFunction": "Get-PluginNotetags"
    },
    "method_touches": {
      "description": "Method-touch extraction for conflict analysis",
      "required": true,
      "parserFunction": "Get-PluginMethodTouches"
    },
    "conflict_signatures": {
      "description": "Conflict-signature extraction",
      "required": true,
      "parserFunction": "Get-PluginConflicts"
    },
    "compatibility_rules": {
      "description": "Compatibility extraction",
      "required": true,
      "parserFunction": "Test-PluginConflict"
    },
    "tool_patterns": {
      "description": "Tool pattern extraction",
      "required": true,
      "parserFunction": "Get-PluginToolPatterns"
    }
  },
  "retrievalProfiles": {
    "api-lookup": {
      "description": "Engine API reference questions",
      "preferredCollections": ["rpgmaker_core_api"]
    },
    "plugin-pattern": {
      "description": "Plugin development patterns",
      "preferredCollections": ["rpgmaker_plugin_patterns", "rpgmaker_core_api"]
    },
    "conflict-diagnosis": {
      "description": "Plugin conflict analysis",
      "preferredCollections": ["rpgmaker_tooling", "rpgmaker_private_project"],
      "requiredEvidence": ["conflict_signatures", "method_touches"]
    },
    "codegen": {
      "description": "Plugin code generation",
      "preferredCollections": ["rpgmaker_plugin_patterns", "rpgmaker_core_api"]
    },
    "private-project-first": {
      "description": "Project-local questions",
      "preferredCollections": ["rpgmaker_private_project", "rpgmaker_core_api"]
    },
    "tooling-workflow": {
      "description": "Tool and workflow questions",
      "preferredCollections": ["rpgmaker_tooling", "rpgmaker_llm_workflows"]
    }
  },
  "owners": {
