    },
    "voice-cloning": {
      "description": "Voice cloning and speaker embedding questions",
      "preferredCollections": ["voice_cloning"]
    },
    "audio-processing": {
      "description": "Audio preprocessing and feature extraction",
      "preferredCollections": ["audio_processing"]
    },
    "voice-conversion": {
      "description": "Voice conversion and style transfer",
      "preferredCollections": ["voice_conversion", "voice_cloning"]
    },
    "inference-optimization": {
      "description": "Optimization for voice generation inference",
      "preferredCollections": ["text_to_speech", "voice_cloning"]
    }
  },
  "owners": {
    "owners": ["Doc"],
    "reviewers": ["pack-maintainer-1"],
    "defaultPromotionPolicy": "owner-or-reviewer-approval",
    "escalationContact": "Doc"
  },
