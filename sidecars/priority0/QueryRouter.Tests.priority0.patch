## Patch: add arbitration-isolation regression test

Recommended test file scaffold:

```powershell
Describe "QueryRouter Priority 0 regressions" {
    BeforeAll {
        . "$PSScriptRoot/../module/LLMWorkflow/retrieval/QueryRouter.ps1"
    }

    It "Returns a routing result when optional cross-pack arbitration throws" {
        Mock Get-RetrievalProfile {
            return @{
                profileName = 'api-lookup'
                description = 'API reference and documentation queries'
                packPreferences = @{
                    primary = @('core-engine')
                    secondary = @('language-binding')
                    avoid = @()
                }
                evidenceTypes = @('api-reference')
                minAuthorityScore = 0.1
                requireMultipleSources = $false
            }
        }

        Mock Get-QueryIntent {
            return @{
                primaryIntent = 'api-lookup'
                secondaryIntent = $null
                confidence = 0.9
                scores = @{ 'api-lookup' = 100 }
                matchedKeywords = @{ 'api-lookup' = @('api') }
                allIntents = @('api-lookup')
                correlationId = 'test-correlation'
            }
        }

        Mock Route-QueryToPacks {
            return @{
                selectedPacks = @('pack-a', 'pack-b')
                packOrder = @(
                    [pscustomobject]@{ packId = 'pack-a'; score = 0.8; reason = 'Primary' },
                    [pscustomobject]@{ packId = 'pack-b'; score = 0.75; reason = 'Secondary' }
                )
                primaryPack = 'pack-a'
                isCrossPack = $true
                confidence = 0.8
            }
        }

        Mock Get-Command {
            param($Name)
            if ($Name -eq 'Invoke-CrossPackArbitration') {
                return @{ Name = 'Invoke-CrossPackArbitration' }
            }
            return $null
        }

        Mock Invoke-CrossPackArbitration {
            throw 'arbitration exploded'
        }

        $result = Invoke-QueryRouting -Query 'api docs for signals' -EnableArbitration $true

        $result | Should -Not -BeNullOrEmpty
        $result.selectedPacks.Count | Should -Be 2
        $result.primaryPack | Should -Be 'pack-a'
        $result.error | Should -BeNullOrEmpty
    }
}
```

Expected effect:
- fails against the current behavior if arbitration exception bubbles into the outer catch
- passes once arbitration is isolated as optional and routing continues
