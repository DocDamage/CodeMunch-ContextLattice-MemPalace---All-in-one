## Patch A: verify unavailable-Docling path remains graceful

```powershell
Describe "DoclingAdapter Priority 0 regressions" {
    BeforeAll {
        . "$PSScriptRoot/../module/LLMWorkflow/ingestion/DoclingAdapter.ps1"
    }

    It "Returns a failure record instead of throwing when Docling is unavailable" {
        $tmp = Join-Path $TestDrive 'sample.pdf'
        'fake pdf bytes' | Set-Content -LiteralPath $tmp

        $adapter = New-DoclingAdapter -PythonPath 'C:\NonExistent\python.exe' -TimeoutSeconds 1
        $result = Invoke-DoclingExtraction -FilePath $tmp -Adapter $adapter

        $result | Should -Not -BeNullOrEmpty
        $result.success | Should -Be $false
        $result.engine | Should -Match 'docling'
        $result.errors.Count | Should -BeGreaterThan 0
    }
}
```

