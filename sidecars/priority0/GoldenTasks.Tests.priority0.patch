## Patch A: add confidence aggregation regression

```powershell
Describe "GoldenTasks Priority 0 regressions" {
    BeforeAll {
        . "$PSScriptRoot/../module/LLMWorkflow/governance/GoldenTasks.ps1"
    }

    It "Uses Validation.Confidence when summarizing golden task pack runs" {
        $script:testTasks = @(
            New-GoldenTask -TaskId 'gt-priority0-001' -Name 'Task 1' -PackId 'priority0-pack' -Query 'Query 1' -ExpectedResult @{ result = 'ok' },
            New-GoldenTask -TaskId 'gt-priority0-002' -Name 'Task 2' -PackId 'priority0-pack' -Query 'Query 2' -ExpectedResult @{ result = 'ok' }
        )

        Mock Get-PredefinedGoldenTasks {
            return $script:testTasks
        }

        Mock Invoke-GoldenTask {
            param($Task)
            switch ($Task.taskId) {
                'gt-priority0-001' {
                    return @{
                        Task = @{ TaskId = 'gt-priority0-001' }
                        Success = $true
                        Validation = @{ Success = $true; Confidence = 0.95 }
                    }
                }
                'gt-priority0-002' {
                    return @{
                        Task = @{ TaskId = 'gt-priority0-002' }
                        Success = $true
                        Validation = @{ Success = $true; Confidence = 0.65 }
                    }
                }
            }
        }

        $result = Invoke-PackGoldenTasks -PackId 'priority0-pack'

        $result.TasksRun | Should -Be 2
        $result.Passed | Should -Be 2
        $result.AverageConfidence | Should -Be 0.8
    }
}
```

